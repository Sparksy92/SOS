[Unit]
Description=SurvivalOS Backend Express Service
After=network.target

[Service]
Type=simple
User=bs
WorkingDirectory=/home/bs/projects/survival/sos-server
ExecStart=/usr/bin/node index.js
Restart=on-failure
Environment=NODE_ENV=production PORT=3001 SOS_MATERIALS_DIR=/media/bs/JARVIS/SurvivalOS_Library
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
