[Unit]
Description=SurvivalOS Backend Express Service
After=network.target

[Service]
Type=simple
User=YOUR_SYSTEM_USER
WorkingDirectory=/path/to/survival/sos-server
ExecStart=/usr/bin/node index.js
Restart=on-failure
Environment=NODE_ENV=production PORT=3001 SOS_MATERIALS_DIR=/path/to/your/library
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
