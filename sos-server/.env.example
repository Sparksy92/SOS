# SurvivalOS Backend Configurations

# Specify the absolute path to your local materials reference folder (leave blank to default to app root)
SOS_MATERIALS_DIR=

# Disable automatic background crawling/indexing of materials (highly recommended to prevent CPU spikes)
SOS_AUTO_CRAWL=false

# Port number for the express backend API server
PORT=3001

# Ollama Connection Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Language & Embedding Model names
SOS_EMBEDDING_MODEL=nomic-embed-text
SOS_LLM_MODEL=llama3.1:8b

# Neural TTS service connection URL
SOS_TTS_URL=http://localhost:3002

# Custom paths for DB and Vector store (leave blank to use defaults in app root)
SOS_DB_PATH=
SOS_VECTOR_STORE_PATH=

# Node Environment
NODE_ENV=production
